from sage.all import *
from Crypto.Util.number import long_to_bytes

n1 = 
n2 = 
n3 = 

c1 = 
c2 = 
c3 = 

N = n1*n2*n3

# CRT coefficients
T1 = crt([1,0,0],[n1,n2,n3])
T2 = crt([0,1,0],[n1,n2,n3])
T3 = crt([0,0,1],[n1,n2,n3])

R.<x> = PolynomialRing(Zmod(N))

f = (
    T1*((x+46)^3 - c1) +
    T2*((x+33)^3 - c2) +
    T3*((x+63)^3 - c3)
)

# M is < 2^480
roots = f.small_roots(X=2^480, beta=1)

print(roots)

M = int(roots[0])

flag = long_to_bytes(M // 256)
print(flag.decode())